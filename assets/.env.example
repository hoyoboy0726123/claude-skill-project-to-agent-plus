# ─── LLM provider (pick at least one) ──────────────────────────────────
# llm_client.py auto-detects: 第一個有設 key 的 provider 被選中,
# 或設 AGENT_LLM_PROVIDER 強制指定。

# Gemini / Gemma (Google AI Studio) — 預設、免費 tier
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemma-4-31b-it

# Groq — 快、免費 tier 大方
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (local、無 key,需在本機跑 ollama serve)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# 強制指定 provider (蓋掉 auto-detect)。可選:gemini / groq / openai / anthropic / ollama
# AGENT_LLM_PROVIDER=gemini

# ─── Telegram bot (Phase 8 必填) ──────────────────────────────────────
# Get token: 跟 @BotFather 對話、/newbot
TELEGRAM_BOT_TOKEN=
# 逗號分隔 user IDs (跟 @userinfobot 拿)。空 = dev mode,任何人都可以聊
TELEGRAM_AUTHORIZED_USERS=

# ─── Web search (Phase 11 選用) ───────────────────────────────────────
# Get key: https://tavily.com (1000/月免費)
TAVILY_API_KEY=

# ─── Shell sandbox (Phase 10 選用) ────────────────────────────────────
# true = 啟用 run_shell + run_python tools(沒 opt-in 就不會出現在 LLM 工具集)
ENABLE_SHELL_TOOL=false
# 'host' = shell 直接在 OS 跑(僅 allowlist 內讀檔指令會跑)
# 'sandbox' = WSL Docker 容器內跑(任意指令、container 是邊界、需先跑 sandbox/setup_sandbox.bat)
AGENT_SANDBOX_MODE=host

# ─── Self-evolution (Phase 12 選用) ───────────────────────────────────
# true = 解鎖 propose_tool / merge_proposed_tool / reject_proposed_tool / list_proposed_tools
# 需 Phase 7 permissions + Phase 10 shell 都已就緒
ENABLE_SELF_EVOLUTION=false
